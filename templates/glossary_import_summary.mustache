<div class="generalbox">
  <h2 class="h3">{{#str}} importsummary, filter_translations {{/str}}</h2>
  <p>{{#str}} processedcount, filter_translations, {{processedcount}} {{/str}}</p>
  <p>{{#str}} glossarycreatedcount, filter_translations, {{createdcount}} {{/str}}</p>
  <p>{{#str}} glossaryupdatedcount, filter_translations, {{updatedcount}} {{/str}}</p>
  <p>{{#str}} skippedcount, filter_translations, {{skippedcount}} {{/str}}</p>

  {{#hasskipped}}
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>{{#str}} linenumber, filter_translations {{/str}}</th>
          <th>{{#str}} sourcephrase, filter_translations {{/str}}</th>
          <th>{{#str}} targetlanguage, filter_translations {{/str}}</th>
          <th>{{#str}} reason, filter_translations {{/str}}</th>
        </tr>
      </thead>
      <tbody>
        {{#skipped}}
          <tr>
            <td>{{linenum}}</td>
            <td>{{sourcephrase}}</td>
            <td>{{targetlanguage}}</td>
            <td>{{reason}}</td>
          </tr>
        {{/skipped}}
      </tbody>
    </table>
  {{/hasskipped}}

  <p><a class="btn btn-primary" href="{{continueurl}}">{{#str}} continue {{/str}}</a></p>
</div>
